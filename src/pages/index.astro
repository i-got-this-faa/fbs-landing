---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>FBS | Fast Blob Storage</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://unpkg.com/@phosphor-icons/web"></script>
  <style>
    @font-face {
      font-family: 'NeueMontreal';
      src: url('https://cdn.jsdelivr.net/fontsource/fonts/inter@latest/latin-900-normal.woff2') format('woff2');
      font-weight: 900;
    }
    @font-face {
      font-family: 'Space Mono';
      src: url('https://cdn.jsdelivr.net/fontsource/fonts/space-mono@latest/latin-400-normal.woff2') format('woff2');
    }

    :root {
      --bg-color: #dcdcdc;
      --text-color: #111111;
      --accent-color: #ff3300;
      --invert-bg: #111111;
      --invert-text: #dcdcdc;
    }

    html.dark {
      --bg-color: #111111;
      --text-color: #dcdcdc;
      --accent-color: #ff3300;
      --invert-bg: #dcdcdc;
      --invert-text: #111111;
    }
    
    body {
      font-family: 'Space Mono', monospace;
      margin: 0;
      padding: 0;
      overflow-x: hidden;
      cursor: crosshair;
      background-color: var(--bg-color);
      color: var(--text-color);
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    ::selection {
      background-color: var(--accent-color);
      color: #fff;
    }

    h1, h2, h3, .brutal-title {
      font-family: 'NeueMontreal', sans-serif;
      text-transform: uppercase;
      line-height: 0.8;
      letter-spacing: -0.05em;
    }

    /* Custom Cursor / Blob */
    #cursor-blob {
      position: fixed;
      top: 0;
      left: 0;
      width: 40vmax;
      height: 40vmax;
      background: radial-gradient(circle, var(--accent-color) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      transform: translate(-50%, -50%);
      z-index: 0;
      opacity: 0.6;
      filter: blur(40px);
      transition: transform 0.1s ease-out;
    }

    /* Functional Header */
    .brutal-header {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      padding: 1.5rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 50;
      font-weight: bold;
      text-transform: uppercase;
      font-size: 0.875rem;
      letter-spacing: -0.05em;
      border-bottom: 2px solid var(--text-color);
      background: var(--bg-color);
      transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    .brutal-header button {
      background: transparent;
      border: none;
      color: var(--text-color);
      font-family: inherit;
      font-weight: bold;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .brutal-header button:hover {
      color: var(--accent-color);
    }

    /* Marquee */
    .marquee {
      white-space: nowrap;
      overflow: hidden;
      display: flex;
      border-top: 4px solid var(--text-color);
      border-bottom: 4px solid var(--text-color);
      padding: 1rem 0;
      background: var(--invert-bg);
      color: var(--invert-text);
      transition: all 0.3s ease;
    }
    .marquee span {
      display: inline-block;
      animation: scroll 20s linear infinite;
      font-size: 3rem;
      font-weight: 900;
      padding-right: 2rem;
    }
    @keyframes scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-100%); }
    }

    /* Grid layout */
    .b-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1rem;
    }

    /* Abstract shapes */
    .shape-container {
      clip-path: polygon(0% 0%, 100% 0%, 100% 75%, 75% 100%, 0% 100%);
      background: var(--invert-bg);
      color: var(--invert-text);
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Utility */
    .huge-text {
      font-size: clamp(5rem, 14vw, 20rem);
    }

    /* Border styles adapting to theme */
    .border-theme {
      border-color: var(--text-color);
    }
  </style>
</head>
<body class="antialiased relative">
  <div id="cursor-blob"></div>

  <!-- Functional Header -->
  <header class="brutal-header">
    <div class="flex items-center gap-4">
      <i class="ph-bold ph-hexagon text-xl"></i>
      <span>FBS // ENGINE</span>
    </div>
    <div class="flex items-center gap-8">
      <a href="https://github.com/fbs" class="hidden md:block hover:text-[var(--accent-color)] transition-colors">SOURCE_CODE</a>
      <button id="theme-toggle" aria-label="Toggle Dark Mode">
        <i class="ph-fill ph-moon"></i>
        <span>INVERT</span>
      </button>
    </div>
  </header>

  <!-- Intro Screen / Manifesto -->
  <main class="min-h-screen relative p-4 md:p-8 flex flex-col justify-end z-10 pt-32">
    <div class="my-auto b-grid">
      <div class="col-span-12 md:col-span-10 md:col-start-2">
        <h1 class="brutal-title huge-text text-[var(--text-color)]">
          FAST<br/>BLOB<br/>STOR<span class="anim-a inline-block">A</span><span class="anim-g inline-block">G</span><span class="anim-e inline-block">E</span>
        </h1>
      </div>
    </div>

    <div class="b-grid items-end pb-8">
      <div class="col-span-12 md:col-span-4 border-l-4 border-theme pl-4">
        <p class="text-xl md:text-2xl uppercase font-bold leading-tight">
          S3-Compatible. Built for the homelab.
        </p>
        <p class="mt-4 text-sm max-w-sm opacity-80">
          Drop-in S3 compatibility without the enterprise bloat. A blazing fast, ultra-lightweight, single-node storage engine.
        </p>
      </div>
      <div class="col-span-12 md:col-span-4 md:col-start-9 text-right mt-12 md:mt-0">
        <i class="ph-fill ph-hard-drives text-[8rem] text-[var(--text-color)] opacity-20"></i>
      </div>
    </div>
  </main>

  <div class="marquee">
    <span>NO GOSSIP PROTOCOLS &nbsp;&bull;&nbsp; NO 4-DRIVE MINIMUMS &nbsp;&bull;&nbsp; NO 500MB IDLE RAM &nbsp;&bull;&nbsp; PURE PERFORMANCE &nbsp;&bull;&nbsp; NO GOSSIP PROTOCOLS &nbsp;&bull;&nbsp; NO 4-DRIVE MINIMUMS &nbsp;&bull;&nbsp; NO 500MB IDLE RAM &nbsp;&bull;&nbsp; PURE PERFORMANCE &nbsp;&bull;&nbsp;</span>
  </div>

  <!-- Anatomy Section - Brutalist Asymmetry -->
  <section class="min-h-screen p-4 md:p-8 relative z-10 my-32">
    <div class="b-grid h-full">
      
      <!-- Sticky Sidebar -->
      <div class="col-span-12 md:col-span-3">
        <div class="sticky top-32">
          <h2 class="brutal-title text-5xl md:text-8xl mb-8">THE<br/>GUTS.</h2>
          <div class="flex flex-col gap-2 font-bold uppercase text-sm border-t-2 border-theme pt-4">
            <span class="flex justify-between"><span>Engine</span> <span>Go / SQLite</span></span>
            <span class="flex justify-between"><span>Auth</span> <span>SigV4 / Bearer</span></span>
            <span class="flex justify-between"><span>UI</span> <span>SvelteKit / OpenTUI</span></span>
          </div>
        </div>
      </div>

      <!-- Content Area -->
      <div class="col-span-12 md:col-span-8 md:col-start-5 mt-20 md:mt-0 flex flex-col gap-32">
        
        <!-- Block 1 -->
        <article class="shape-container p-8 md:p-16 hover:!bg-[var(--accent-color)] hover:!text-[#111] transition-all duration-500 group relative overflow-hidden">
          <i class="ph-duotone ph-database text-[15rem] absolute -right-10 -bottom-10 opacity-10 group-hover:opacity-30 group-hover:scale-110 transition-all"></i>
          <h3 class="text-4xl md:text-6xl brutal-title mb-8 relative z-10">Data before<br/>Metadata</h3>
          <p class="text-lg md:text-2xl max-w-xl font-bold leading-relaxed relative z-10">
            Write to .tmp. Rename atomically. Insert to SQLite. 
            If the row isn't there, the data isn't there.
          </p>
        </article>

        <!-- Block 2 -->
        <article class="border-4 border-theme p-8 md:p-16 relative bg-transparent overflow-hidden group">
          <div class="absolute inset-0 bg-[var(--text-color)] translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-in-out"></div>
          <div class="relative z-10 group-hover:text-[var(--bg-color)] transition-colors duration-500">
            <h3 class="text-4xl md:text-6xl brutal-title mb-8">Zero-Copy<br/>Egress</h3>
            <p class="text-lg md:text-2xl max-w-xl font-bold leading-relaxed">
              We bypass userspace completely. Linux sendfile() blasts bits straight from disk to network socket.
            </p>
          </div>
        </article>

        <!-- Block 3 -->
        <article class="shape-container p-8 md:p-16 !bg-[var(--text-color)] !text-[var(--bg-color)] flex flex-col items-start relative">
          <div class="bg-[var(--accent-color)] text-black font-bold px-4 py-1 uppercase text-sm mb-8 inline-block rotate-[-2deg]">
            Checksum Pipeline
          </div>
          <h3 class="text-4xl md:text-6xl brutal-title mb-8">TeeReader<br/>Validation</h3>
          <p class="text-lg md:text-2xl max-w-xl font-bold leading-relaxed opacity-80">
            Hashing data as it streams to disk. MD5 & x-amz-checksums verified at wire speed. Corrupt data dies before it lives.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Huge Footer / Interaction Area -->
  <footer class="min-h-[60vh] bg-[var(--text-color)] text-[var(--bg-color)] p-4 md:p-8 flex flex-col justify-center items-center relative overflow-hidden z-10 transition-colors duration-300">
    <div class="absolute inset-0 opacity-5 grid place-items-center pointer-events-none">
      <i class="ph-fill ph-asterisk text-[100vw] rotate-45"></i>
    </div>

    <div class="z-10 w-full text-center">
      <h2 class="brutal-title huge-text text-[var(--bg-color)] hover:text-[var(--accent-color)] transition-colors cursor-pointer select-none">
        DEPLOY
      </h2>
    </div>
  </footer>

  <script>
    // --- Blob Cursor Effect ---
    const blob = document.getElementById('cursor-blob');
    let mouseX = 0;
    let mouseY = 0;
    let blobX = 0;
    let blobY = 0;

    window.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    function animateBlob() {
      blobX += (mouseX - blobX) * 0.1;
      blobY += (mouseY - blobY) * 0.1;
      
      if (blob) {
        blob.style.transform = `translate(calc(${blobX}px - 50%), calc(${blobY}px - 50%))`;
      }
      requestAnimationFrame(animateBlob);
    }
    animateBlob();

    // --- Dark Mode Toggle ---
    const themeToggle = document.getElementById('theme-toggle');
    const htmlElement = document.documentElement;
    const themeIcon = themeToggle.querySelector('i');

    // Check local storage for theme preference
    if (localStorage.getItem('theme') === 'dark') {
      htmlElement.classList.add('dark');
      themeIcon.classList.replace('ph-moon', 'ph-sun');
    }

    themeToggle.addEventListener('click', () => {
      htmlElement.classList.toggle('dark');
      const isDark = htmlElement.classList.contains('dark');
      
      if (isDark) {
        localStorage.setItem('theme', 'dark');
        themeIcon.classList.replace('ph-moon', 'ph-sun');
      } else {
        localStorage.setItem('theme', 'light');
        themeIcon.classList.replace('ph-sun', 'ph-moon');
      }
    });

    // --- Parallax Scroll Animation for "AGE" ---
    const animA = document.querySelector('.anim-a');
    const animG = document.querySelector('.anim-g');
    const animE = document.querySelector('.anim-e');

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      
      // Calculate translate values based on scroll position
      // A moves up a little, G moves up more, E moves up the most
      if (animA) animA.style.transform = `translateY(-${scrollY * 0.1}px)`;
      if (animG) animG.style.transform = `translateY(-${scrollY * 0.25}px)`;
      if (animE) animE.style.transform = `translateY(-${scrollY * 0.45}px)`;
    });
  </script>
</body>
</html>