---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import type { DocHeading, DocNavItem, DocPage } from '../lib/docs';

interface Props {
  doc: DocPage;
  nav: DocNavItem[];
}

const { doc, nav } = Astro.props;

function hrefFor(slug: string) {
  return slug === 'README' ? '/docs/' : `/docs/${slug}/`;
}
---

<BaseLayout title={`${doc.title} | FBS Docs`} description={doc.description}>
  <Header />
  <main class="relative z-10 min-h-screen bg-[var(--bg-color)] pt-[var(--site-header-height)] text-[var(--text-color)]">
    <div class="mx-auto grid max-w-[1440px] grid-cols-1 lg:grid-cols-[280px_minmax(0,1fr)] xl:grid-cols-[280px_minmax(0,1fr)_260px]">
      <aside class="border-b-2 border-[var(--text-color)] bg-[var(--bg-color)] lg:sticky lg:top-[var(--site-header-height)] lg:h-[calc(100vh_-_var(--site-header-height))] lg:border-b-0 lg:border-r-2">
        <nav class="px-4 py-4 lg:py-8" aria-label="Documentation">
          <div class="mb-3 px-3 text-xs font-bold uppercase tracking-[0.18em] text-[var(--accent-color)]">Documentation</div>
          <div class="flex gap-2 overflow-x-auto pb-1 lg:flex-col lg:overflow-visible lg:pb-0">
            {nav.map((item) => (
              <a
                href={hrefFor(item.slug)}
                class={`shrink-0 border-2 px-3 py-2 text-sm font-bold uppercase leading-tight transition-colors lg:shrink ${
                  item.slug === doc.slug
                    ? 'border-[var(--accent-color)] bg-[var(--accent-color)] text-white'
                    : 'border-transparent text-[var(--text-color)] hover:border-[var(--text-color)] hover:bg-[var(--invert-bg)] hover:text-[var(--invert-text)]'
                }`}
              >
                {item.title}
              </a>
            ))}
          </div>
        </nav>
      </aside>

      <article class="min-w-0 px-4 py-10 md:px-8 lg:px-12 lg:py-14">
        <header class="mb-10 border-b-2 border-[var(--text-color)] pb-8">
          <h1 class="brutal-title max-w-4xl text-5xl md:text-7xl">
            {doc.title}
          </h1>
          {doc.description && <p class="mt-6 max-w-3xl text-base font-bold uppercase leading-relaxed md:text-lg">{doc.description}</p>}
        </header>

        <div class="doc-content" set:html={doc.html} />
      </article>

      <aside class="hidden border-l-2 border-[var(--text-color)] px-5 py-14 xl:sticky xl:top-[var(--site-header-height)] xl:block xl:h-[calc(100vh_-_var(--site-header-height))]">
        <div>
          <div class="mb-3 text-xs font-bold uppercase tracking-[0.18em] text-[var(--accent-color)]">On This Page</div>
          {doc.headings.length > 0 ? (
            <nav class="flex max-h-[calc(100vh-9rem)] flex-col gap-2 overflow-y-auto pr-1" aria-label="On this page">
              {doc.headings.map((heading: DocHeading) => (
                <a
                  href={`#${heading.id}`}
                  data-toc-link={heading.id}
                  class={`toc-link block border-l-2 border-transparent py-1 pl-3 text-sm leading-snug opacity-70 transition-colors hover:border-[var(--accent-color)] hover:text-[var(--accent-color)] hover:opacity-100 ${
                    heading.depth === 3 ? 'pl-5 text-xs' : ''
                  }`}
                >
                  {heading.text}
                </a>
              ))}
            </nav>
          ) : (
            <p class="text-sm opacity-60">No sections.</p>
          )}
        </div>
      </aside>
    </div>
  </main>

  <script>
    const tocLinks = Array.from(document.querySelectorAll<HTMLElement>('[data-toc-link]'));
    const headings = tocLinks
      .map((link) => {
        const id = link.getAttribute('data-toc-link');
        return id ? document.getElementById(id) : null;
      })
      .filter((heading): heading is HTMLElement => heading !== null);

    function setActiveTocLink(activeId: string) {
      for (const link of tocLinks) {
        link.classList.toggle('is-active', link.getAttribute('data-toc-link') === activeId);
      }

      const activeLink = tocLinks.find((link) => link.getAttribute('data-toc-link') === activeId);
      activeLink?.scrollIntoView({ block: 'nearest' });
    }

    function updateActiveTocLink() {
      const documentElement = document.documentElement;
      const remainingScroll = Math.max(0, documentElement.scrollHeight - window.scrollY - window.innerHeight);
      const normalActivationLine = Math.min(window.innerHeight * 0.35, 280);
      const endActivationLine = Math.max(normalActivationLine, window.innerHeight - 40);
      const endZone = Math.min(Math.max(window.innerHeight * 0.45, 320), 520);
      const endProgress = 1 - Math.min(remainingScroll / endZone, 1);
      const activationLine = normalActivationLine + (endActivationLine - normalActivationLine) * endProgress;

      let activeHeading = headings[0];

      for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= activationLine) {
          activeHeading = heading;
        } else {
          break;
        }
      }

      if (activeHeading) {
        setActiveTocLink(activeHeading.id);
      }
    }

    let ticking = false;
    function requestTocUpdate() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        updateActiveTocLink();
        ticking = false;
      });
    }

    updateActiveTocLink();
    window.addEventListener('scroll', requestTocUpdate, { passive: true });
    window.addEventListener('resize', requestTocUpdate);
    window.addEventListener('hashchange', requestTocUpdate);
  </script>
</BaseLayout>
