---
---
<section class="py-16 md:py-24 px-4 md:px-8 relative z-10 border-t-4 border-b-4 border-theme bg-(--invert-bg) text-(--invert-text)">
  <div class="max-w-4xl mx-auto">
    <h2 class="brutal-title text-6xl md:text-8xl mb-12">GET STARTED.</h2>

    <!-- Terminal Window -->
    <div class="border-4 border-(--invert-text)">
      <!-- Chrome -->
      <div class="border-b-4 border-(--invert-text) px-4 py-3 flex items-center gap-3 bg-(--invert-bg)">
        <div class="flex gap-2">
          <div class="w-3 h-3 bg-(--accent-color)"></div>
          <div class="w-3 h-3 bg-(--invert-text)/30"></div>
          <div class="w-3 h-3 bg-(--invert-text)/30"></div>
        </div>
        <span class="text-xs font-bold uppercase opacity-30 ml-2">fbs-session</span>
        <button id="copy-all" class="ml-auto text-xs font-bold uppercase opacity-0 hover:opacity-100 transition-opacity cursor-pointer flex items-center gap-1" aria-label="Copy all">
          <i class="ph-fill ph-copy"></i>
        </button>
      </div>

      <!-- Body -->
      <div class="bg-(--bg-color) text-(--text-color) p-5 md:p-6 text-sm font-mono leading-relaxed overflow-x-auto">
        <div class="space-y-5">
          <!-- Step 1 -->
          <div>
            <div class="flex items-start gap-2">
              <span class="text-(--accent-color) font-bold select-none shrink-0">$</span>
              <code>go install github.com/i-got-this-faa/fbs-core/cmd/server@latest</code>
            </div>
          </div>

          <!-- Step 2 -->
          <div>
            <div class="flex items-start gap-2">
              <span class="text-(--accent-color) font-bold select-none shrink-0">$</span>
              <div class="space-y-1">
                <code>export FBS_PORT=8080</code>
                <br/>
                <code>export FBS_DATA_DIR=/var/lib/fbs</code>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div>
            <div class="flex items-start gap-2">
              <span class="text-(--accent-color) font-bold select-none shrink-0">$</span>
              <code>fbs-server</code>
            </div>
            <div class="mt-1 ml-4 opacity-40">
              <code>[INFO] listening on :8080</code>
            </div>
          </div>

          <!-- Step 4 -->
          <div>
            <div class="flex items-start gap-2">
              <span class="text-(--accent-color) font-bold select-none shrink-0">$</span>
              <div>
                <code>aws s3 cp file.txt s3://mybucket/ \</code>
                <br/>
                <code>&nbsp;&nbsp;--endpoint-url http://localhost:8080</code>
              </div>
            </div>
            <div class="mt-1 ml-4 opacity-40">
              <code>upload: ./file.txt to s3://mybucket/file.txt</code>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      var btn = document.getElementById('copy-all');
      var terminal = btn?.closest('.border-4')?.querySelector('.bg-\\(--bg-color\\)');
      if (!btn || !terminal) return;

      btn.style.opacity = '0.4';

      btn.addEventListener('click', function() {
        var text = terminal.innerText || '';
        navigator.clipboard.writeText(text.trim());
        var icon = btn.querySelector('i');
        if (icon) {
          icon.classList.replace('ph-copy', 'ph-check');
          setTimeout(function() {
            icon.classList.replace('ph-check', 'ph-copy');
          }, 1200);
        }
      });
    })();
  </script>
</section>
