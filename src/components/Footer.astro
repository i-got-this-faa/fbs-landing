---
---
<footer class="min-h-[60vh] bg-(--text-color) text-(--bg-color) p-4 md:p-8 flex flex-col justify-center items-center relative overflow-hidden z-10 transition-colors duration-300">
  <div class="absolute inset-0 opacity-40 grid place-items-center pointer-events-none">
    <div class="relative w-[118vw] max-w-300 aspect-square -translate-y-[2%]">
      <svg viewBox="0 0 1000 1000" class="size-full overflow-visible text-(--bg-color)">
        <g class="footer-platter">
          <circle cx="500" cy="500" r="470" fill="currentColor" fill-opacity="0.06" stroke="currentColor" stroke-opacity="0.3" stroke-width="14" />
          <circle cx="500" cy="500" r="385" fill="none" stroke="currentColor" stroke-opacity="0.22" stroke-width="3" />
          <circle cx="500" cy="500" r="300" fill="none" stroke="currentColor" stroke-opacity="0.18" stroke-width="2.5" />
          <circle cx="500" cy="500" r="215" fill="none" stroke="currentColor" stroke-opacity="0.14" stroke-width="2" />

          <!-- Enhanced Spindle Motor -->
          <circle cx="500" cy="500" r="110" fill="currentColor" fill-opacity="0.1" stroke="currentColor" stroke-opacity="0.2" stroke-width="2" />
          <circle cx="500" cy="500" r="78" fill="currentColor" fill-opacity="0.24" stroke="currentColor" stroke-opacity="0.35" stroke-width="4" />
          <circle cx="500" cy="500" r="54" fill="none" stroke="currentColor" stroke-opacity="0.3" stroke-width="6" stroke-dasharray="10 6" />
          <circle cx="500" cy="500" r="34" fill="currentColor" fill-opacity="0.55" stroke="currentColor" stroke-opacity="0.42" stroke-width="2" />
          <circle cx="500" cy="500" r="12" fill="var(--bg-color)" fill-opacity="0.8" />

          <circle cx="500" cy="428" r="8" fill="currentColor" fill-opacity="0.62" />
          <circle cx="562" cy="464" r="8" fill="currentColor" fill-opacity="0.62" />
          <circle cx="562" cy="536" r="8" fill="currentColor" fill-opacity="0.62" />
          <circle cx="500" cy="572" r="8" fill="currentColor" fill-opacity="0.62" />
          <circle cx="438" cy="536" r="8" fill="currentColor" fill-opacity="0.62" />
          <circle cx="438" cy="464" r="8" fill="currentColor" fill-opacity="0.62" />
        </g>

        <g transform="rotate(-20 500 500)">
          <!-- Pivot bearing (stationary relative to group, outside platter) -->
          <g style="color: var(--accent-color)" opacity="0.95">
            <circle cx="1020" cy="500" r="50" fill="currentColor" fill-opacity="0.34" stroke="currentColor" stroke-opacity="0.75" stroke-width="6" />
            <circle cx="1020" cy="500" r="35" fill="none" stroke="currentColor" stroke-opacity="0.4" stroke-width="2" />
            <circle cx="1020" cy="500" r="20" fill="currentColor" fill-opacity="0.72" stroke="currentColor" stroke-opacity="0.65" stroke-width="2" />
            <circle cx="1020" cy="500" r="8" fill="var(--bg-color)" fill-opacity="0.6" />
          </g>

          <!-- Actuator body / Guard (stationary relative to group, rotated to sit above/behind pivot) -->
          <g class="footer-actuator-body" style="color: var(--accent-color)" opacity="0.95" transform="rotate(-55 1020 500)">
            <path d="M 1048 540 C 1100 528, 1138 502, 1164 466 L 1164 548 C 1132 574, 1092 592, 1038 604 Z" fill="currentColor" fill-opacity="0.34" stroke="currentColor" stroke-opacity="0.64" stroke-width="3" />
            <path d="M 1055 545 C 1095 535, 1125 515, 1145 485" fill="none" stroke="currentColor" stroke-opacity="0.4" stroke-width="4" />
            <circle cx="1082" cy="548" r="9" fill="currentColor" fill-opacity="0.8" />
            <circle cx="1082" cy="548" r="3" fill="var(--bg-color)" fill-opacity="0.8" />
            <circle cx="1128" cy="522" r="7" fill="currentColor" fill-opacity="0.7" />
            <circle cx="1128" cy="522" r="2" fill="var(--bg-color)" fill-opacity="0.8" />
          </g>

          <!-- Arm assembly (rotates around pivot) -->
          <g class="footer-arm" style="color: var(--accent-color)">
            <!-- Main thick arm body with triangular cutout -->
            <path fill-rule="evenodd" d="M 1020 470 L 860 486 L 860 510 L 1020 530 Z M 880 498 L 990 516 L 990 484 Z" fill="currentColor" fill-opacity="0.25" stroke="currentColor" stroke-opacity="0.9" stroke-width="3" stroke-linejoin="round" />
            
            <!-- Secondary structural lines / suspension -->
            <path d="M 860 498 L 704 498" fill="none" stroke="currentColor" stroke-opacity="0.8" stroke-width="6" stroke-linecap="round" />
            <path d="M 860 504 L 710 508" fill="none" stroke="currentColor" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round" />

            <!-- Joint circle -->
            <circle cx="860" cy="498" r="14" fill="var(--bg-color)" />
            <circle cx="860" cy="498" r="14" fill="currentColor" fill-opacity="0.58" stroke="currentColor" stroke-opacity="0.75" stroke-width="3" />
            <circle cx="860" cy="498" r="5" fill="var(--bg-color)" fill-opacity="0.8" />
            
            <g class="footer-read-head" opacity="1">
              <path d="M 700 496 L 674 478 L 652 496 L 676 518 Z" fill="currentColor" fill-opacity="0.82" stroke="currentColor" stroke-opacity="0.8" stroke-width="2" />
              <circle cx="672" cy="496" r="5" fill="currentColor" fill-opacity="1" />
              <path d="M 694 498 L 680 486" fill="none" stroke="currentColor" stroke-opacity="0.9" stroke-width="2" stroke-linecap="round" />
            </g>
          </g>
        </g>
      </svg>
    </div>
  </div>

  <div class="z-10 w-full text-center">
    <h2 class="brutal-title huge-text text-(--bg-color) hover:text-(--accent-color) transition-colors cursor-pointer select-none">
      DEPL<span class="footer-anim-o inline-block">O</span><span class="footer-anim-y inline-block">Y</span><span class="footer-anim-bang inline-block">!</span>
    </h2>
    <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm font-bold uppercase opacity-60">
      <a href="https://github.com/i-got-this-faa/fbs-core" class="hover:text-(--accent-color) transition-colors">GitHub</a>
      <span class="opacity-30">|</span>
      <span class="hover:text-(--accent-color) transition-colors cursor-pointer">Documentation</span>
      <span class="opacity-30">|</span>
      <span class="hover:text-(--accent-color) transition-colors cursor-pointer">Releases</span>
    </div>
  </div>
</footer>