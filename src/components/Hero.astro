---
---
<main class="min-h-screen relative p-4 md:p-8 flex flex-col justify-end z-10 pt-32 overflow-hidden bg-[#111111] text-[#dcdcdc]" style="--text-color: #dcdcdc; --invert-text: #111111;">
  <!-- Brutalist image panel -->
  <div class="absolute top-0 right-0 w-full md:w-1/2 h-full z-0">
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat bg-fixed"
      style="background-image: url('/images/orange.png'); clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);"
    ></div>
    <!-- Hard edge shadow for depth -->
    <div
      class="absolute inset-0 bg-[#dcdcdc]/10"
      style="clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);"
    ></div>
  </div>

  <!-- Left side accent strip -->
  <div class="absolute top-0 left-0 w-2 md:w-3 h-full bg-[var(--accent-color)] z-0"></div>

  <div class="my-auto b-grid relative z-10">
    <div class="col-span-12 md:col-span-10 md:col-start-2">
      <h1 class="brutal-title huge-text text-[#dcdcdc]">
        FAST<br/>BLOB<br/>STOR<span class="anim-a inline-block">A</span><span class="anim-g inline-block">G</span><span class="anim-e inline-block">E</span>
      </h1>
    </div>
  </div>

  <div class="b-grid items-end pb-8 relative z-10">
    <div class="col-span-12 md:col-span-8 border-l-4 border-[#dcdcdc] pl-4">
      <p class="text-xl md:text-2xl uppercase font-bold leading-tight text-[#dcdcdc]">
        Self-hosted object storage without the cloud tax.
      </p>
      <p class="mt-4 text-sm max-w-md opacity-80 leading-relaxed text-[#dcdcdc]">
        FBS is a lightweight, single-node storage engine with full S3 compatibility.
      </p>
    </div>
    <div class="col-span-12 md:col-span-4 md:col-start-9 text-right mt-12 md:mt-0">
      <i class="ph-fill ph-hard-drives text-[8rem] text-[#dcdcdc] opacity-20"></i>
    </div>
  </div>
</main>
